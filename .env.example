# Copy to .env and fill in. The project .env wins over inherited shell env.

# Option A — Anthropic (default): just set the key, leave the rest unset
# ANTHROPIC_API_KEY=sk-ant-...

# Option B — any Anthropic-compatible API (e.g. z.ai GLM Coding Plan):
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# ANTHROPIC_AUTH_TOKEN=your-token-here
# FORGECADE_MODEL=glm-5.2

# Optional server settings:
# FORGECADE_PORT=4242
# FORGECADE_HOST=127.0.0.1
